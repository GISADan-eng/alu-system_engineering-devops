#!/usr/bin/env bash
# Configures Nginx to run as nginx user on port 8080

# Create nginx user if it doesn't exist
id -u nginx &>/dev/null || useradd --no-create-home --shell /bin/false nginx

# Update nginx.conf to run as nginx user
sed -i 's/^user www-data;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/^user root;/user nginx;/' /etc/nginx/nginx.conf

# Update all nginx configs to listen on port 8080
find /etc/nginx -name "*.conf" -exec sed -i 's/listen 80;/listen 8080;/g' {} \;
find /etc/nginx -name "*.conf" -exec sed -i 's/listen \[::\]:80;/listen [::]:8080;/g' {} \;
sed -i 's/listen 80;/listen 8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80;/listen [::]:8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen 80 /listen 8080 /g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 /listen [::]:8080 /g' /etc/nginx/sites-available/default

# Restart nginx
nginx -t && service nginx restart
